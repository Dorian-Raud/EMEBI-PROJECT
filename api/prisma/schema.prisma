// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// Configuration de base
generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

// --- RÉFÉRENTIELS ---

model Country {
  code      String   @id @unique // ex: BE, FR, DE
  name      String
  partners  Partner[]
  linesOrig InvoiceLine[] @relation("CountryOrigin")
  linesProv InvoiceLine[] @relation("CountryProv")
}

model Department {
  code     String    @id @unique // ex: 01, 33, 974
  name     String
  partners Partner[]
  headers  InvoiceHeader[]
}

model Nomenclature {
  id          String   @id @default(uuid())
  code        String   // SH8 ex: 85171300
  label       String   @db.Text
  year        Int      // Pour les MAJ annuelles
  lines       InvoiceLine[]
  history     ProductHistory[]

  @@unique([code, year])
}

// --- STRUCTURE CLIENTS (Multi-Sociétés) ---

model Company {
  id              String           @id @default(uuid())
  name            String
  siret           String           @unique
  vatNumber       String           @unique
  declarations    Declaration[]
  companyPartners CompanyPartner[]
}

model Partner {
  id              String           @id @default(uuid())
  name            String
  vatNumber       String           @unique
  isoCode         String
  country         Country          @relation(fields: [isoCode], references: [code])
  deptCode        String?
  department      Department?      @relation(fields: [deptCode], references: [code])

  companies       CompanyPartner[]
  headers         InvoiceHeader[]
  history         ProductHistory[]
  fiscalLines     DeclarationFiscale[]
}

model CompanyPartner {
  companyId  String
  partnerId  String
  company    Company  @relation(fields: [companyId], references: [id])
  partner    Partner  @relation(fields: [partnerId], references: [id])

  @@id([companyId, partnerId])
}

// --- MOUVEMENTS (EMEBI / DEB) ---

enum Flow {
  INTRODUCTION
  EXPEDITION
  FISCALE
}

model DeclarationFiscale {
  id            String       @id @default(uuid())
  createdAt     DateTime     @default(now())
  invoiceNumber String
  invoiceDate   DateTime?
  regime        String
  value         Float

  partnerId     String
  partner       Partner      @relation(fields: [partnerId], references: [id])

  declarationId String
  declaration   Declaration @relation(fields: [declarationId], references: [id])

  @@unique([invoiceNumber, partnerId, declarationId])
}

model Declaration {
  id          String   @id @default(uuid())
  month       Int      
  year        Int
  flow        Flow
  status      String   @default("DRAFT")
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  headers     InvoiceHeader[]
  fiscalLines      DeclarationFiscale[]

  @@unique([companyId, month, year, flow])  // ← ajout
}

model InvoiceHeader {
  id                String    @id @default(uuid())
  createdAt         DateTime  @default(now())
  invoiceNumber     String
  invoiceDate       DateTime?
  regime            String    
  transactionNature String    
  transportMode     String?   
  deptCode          String
  department        Department @relation(fields: [deptCode], references: [code])
  
  partnerId         String
  partner           Partner   @relation(fields: [partnerId], references: [id])
  
  declarationId     String
  declaration       Declaration @relation(fields: [declarationId], references: [id])

  lines             InvoiceLine[]
  @@unique([invoiceNumber, partnerId, declarationId])
}

model InvoiceLine {
  id                String   @id @default(uuid())
  lineNumber        Int

  mass              Float    
  supplementaryUnit Float?   
  value             Float    
  
  // Géographie (pré-remplis via Partner mais éditables)
  originCountryCode String
  originCountry     Country  @relation("CountryOrigin", fields: [originCountryCode], references: [code])
  
  provCountryCode   String
  provCountry       Country  @relation("CountryProv", fields: [provCountryCode], references: [code])
  

  // Nomenclature
  nomenclatureId    String
  nomenclature      Nomenclature @relation(fields: [nomenclatureId], references: [id])
  
  headerId          String
  header            InvoiceHeader @relation(fields: [headerId], references: [id])
}

// --- MÉMOIRE / IA ---

model ProductHistory {
  id             String   @id @default(uuid())
  productLabel   String   
  
  partnerId      String
  partner        Partner  @relation(fields: [partnerId], references: [id])
  
  nomenclatureId String
  nomenclature   Nomenclature @relation(fields: [nomenclatureId], references: [id])

  lastUsed       DateTime @default(now())

  @@unique([partnerId, productLabel])
}